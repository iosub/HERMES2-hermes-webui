# Required: browser/API token for Hermes Web UI
HERMES_WEBUI_TOKEN=changeme

# Optional: explicitly choose the Hermes binary the web UI should manage.
# HERMES_WEBUI_HERMES_BIN=/home/your-user/.hermes/hermes-agent/venv/bin/hermes

# Optional: API-compatible endpoint settings for replay/vision-related flows.
# HERMES_API_URL=http://127.0.0.1:8642
# HERMES_API_KEY=
# HERMES_API_TOKEN=
# API_SERVER_TOKEN=
# HERMES_USE_API=false
